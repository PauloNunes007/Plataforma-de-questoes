# === Supabase ===
# Públicas (vão pro browser) — URL do projeto + chave anon/publishable.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# SECRETA — só no servidor, NUNCA prefixe com NEXT_PUBLIC. Bypassa RLS.
# Necessária pras escritas privilegiadas (XP/liga/streak, ativação de Pro,
# recalibração de tempo médio). Pegue em: Supabase → Project Settings → API →
# service_role (secret). Configure em .env.local e nas env vars do Vercel.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# === Mercado Pago (pagamento do Pro) ===
# SECRETO — Access Token de PRODUÇÃO da sua conta Mercado Pago.
# Painel: mercadopago.com.br → Suas integrações → Credenciais de produção.
# Enquanto vazio, a tela /pro cai no fluxo manual (registra a intenção e você
# confirma em /admin/assinaturas) — sem expor nenhum dado seu.
MP_ACCESS_TOKEN=

# SECRETO — assinatura secreta do webhook (Mercado Pago → Webhooks → "Assinatura
# secreta"). Usada pra validar que a notificação veio mesmo do Mercado Pago.
MP_WEBHOOK_SECRET=

# === App ===
# URL pública do site (sem barra no fim). Usada pras back_urls e a
# notification_url do checkout. Em produção: https://seu-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
